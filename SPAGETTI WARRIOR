//@version=6
indicator("ENDGAME RSI Flow + JC Chart Suite", overlay=true, max_boxes_count=500, max_lines_count=500)

// === SETTINGS ===
rsiLength     = input.int(14, "RSI Length", group="RSI & EMA Settings")
emaFast       = input.int(20, "EMA 20", group="RSI & EMA Settings")
emaSlow       = input.int(50, "EMA 50", group="RSI & EMA Settings")
sweepLength   = input.int(20, "Liquidity Lookback Period", group="Liquidity Settings")

// Institutional Module (JC Purple Boxes & FVG)
showSMC       = input.bool(true, "Show Institutional Purple Zones", group="JC Chart Styles")
fvgThreshold  = input.float(0.0, "Min Zone Size (ATR %)", minval=0.0, group="JC Chart Styles")
showTrendlines= input.bool(true, "Show Chart Trendlines (Channels)", group="Trendline Settings")
trendLookback = input.int(15, "Trendline Pivot Lookback", minval=5, group="Trendline Settings")

// BOLLINGER BANDS (Based on your screenshot settings: BB 60, 1, 0)
bbLength      = input.int(60, "BB Length", group="Bollinger Bands Settings")
bbMult        = input.float(1.0, "BB StdDev", group="Bollinger Bands Settings")
[bbBasis, bbUpper, bbLower] = ta.bb(close, bbLength, bbMult)

// Plot Bollinger Bands (Katulad ng manipis na puti/berde/pulang linya sa screenshot mo)
plot(bbBasis, title="BB Basis", color=color.gray, linewidth=1)
plot(bbUpper, title="BB Upper", color=color.new(color.green, 30), linewidth=1)
plot(bbLower, title="BB Lower", color=color.new(color.red, 30), linewidth=1)

// === EMA ===
ema20 = ta.ema(close, emaFast)
ema50 = ta.ema(close, emaSlow)
plot(ema20, title="EMA 20", color=color.blue, linewidth=1)
plot(ema50, title="EMA 50", color=color.orange, linewidth=1)

// === RSI ===
rsi4h = ta.rsi(close, rsiLength)

// === 1D FILTER ===
rsi1D     = request.security(syminfo.tickerid, "D", ta.rsi(close, rsiLength), barmerge.gaps_off, barmerge.lookahead_off)
ema20_1D  = request.security(syminfo.tickerid, "D", ta.ema(close, emaFast), barmerge.gaps_off, barmerge.lookahead_off)
ema50_1D  = request.security(syminfo.tickerid, "D", ta.ema(close, emaSlow), barmerge.gaps_off, barmerge.lookahead_off)

bullishBias = rsi1D > 50 and ema20_1D > ema50_1D
bearishBias = rsi1D < 50 and ema20_1D < ema50_1D

// === LIQUIDITY SWEEP & SR DETECTION (Purple Horizontal Lines) ===
pHill = ta.highest(high, sweepLength)[1]
pValley = ta.lowest(low, sweepLength)[1]

// Ginawa nating Purple/Lila ang S/R Lines gaya ng horizontal purple lines sa chart mo
plot(pHill, title="JC Resistance Zone", color=color.new(#9c27b0, 40), style=plot.style_line, linestyle=plot.linestyle_solid, linewidth=2)
plot(pValley, title="JC Support Zone", color=color.new(#9c27b0, 40), style=plot.style_line, linestyle=plot.linestyle_solid, linewidth=2)

bullishSweep = low < pValley and close > pValley
bearishSweep = high > pHill and close < pHill

// === JC PREDICTION PURPLE BOXES (FVG / Order Blocks) ===
rangeHigh = ta.highest(high, sweepLength)
rangeLow  = ta.lowest(low, sweepLength)
equilibrium = rangeLow + (rangeHigh - rangeLow) * 0.5
inDiscount  = close < equilibrium

atr = ta.atr(14)
bullishFVG = showSMC and (low[0] > high[2]) and (close[1] > open[1]) and ((low[0] - high[2]) > fvgThreshold * atr)

// Dito iguguhit ang mga Purple Blocks (Lila) kapag may na-detect na structural zone
if bullishFVG
    box.new(left=bar_index[2], top=low[0], right=bar_index + 15, bottom=high[2], 
            bgcolor=color.new(#9c27b0, 85), border_color=color.new(#9c27b0, 40), 
            border_style=line.style_solid)

// === CHART TRENDLINES (Blue & White Channels) ===
var line bearTrendline = na
var line bullTrendline = na

if showTrendlines
    pivotHigh = ta.pivothigh(high, trendLookback, trendLookback)
    pivotLow  = ta.pivotlow(low, trendLookback, trendLookback)

    // Descending Lines (Blue/Red lines matching top patterns)
    if not na(pivotHigh)
        line.set_x2(bearTrendline, bar_index - trendLookback)
        line.set_y2(bearTrendline, pivotHigh)
        bearTrendline := line.new(x1=bar_index - trendLookback, y1=pivotHigh, x2=bar_index, y2=pivotHigh, color=color.new(color.blue, 30), width=2)
    else if not na(bearTrendline)
        line.set_x2(bearTrendline, bar_index)
        if close > line.get_y2(bearTrendline)
            line.set_style(bearTrendline, line.style_dashed)

    // Ascending Lines (White lines matching bottom patterns)
    if not na(pivotLow)
        line.set_x2(bullTrendline, bar_index - trendLookback)
        line.set_y2(bullTrendline, pivotLow)
        bullTrendline := line.new(x1=bar_index - trendLookback, y1=pivotLow, x2=bar_index, y2=pivotLow, color=color.new(color.white, 30), width=2)
    else if not na(bullTrendline)
        line.set_x2(bullTrendline, bar_index)
        if close < line.get_y2(bullTrendline)
            line.set_style(bullTrendline, line.style_dashed)

// === UPGRADED SMART ENTRY ===
sweepConfirmation = ta.barssince(bullishSweep) <= 3
smartBuy = bullishBias and rsi4h > 35 and rsi4h < 45 and ta.crossover(rsi4h, 40) and close > ema20 and sweepConfirmation and inDiscount

// === SIGNALS ===
plotshape(smartBuy, title="INSTITUTIONAL BUY", location=location.belowbar, color=color.green, style=shape.labelup, text="BUY", textcolor=color.white, size=size.normal)
plotshape(bullishSweep and not smartBuy, title="Bullish Sweep", location=location.belowbar, color=color.lime, style=shape.circle, size=size.small)
plotshape(bearishSweep, title="Bearish Sweep", location=location.abovebar, color=color.maroon, style=shape.circle, size=size.small)

// === BACKGROUND TREND ===
bgcolor(bullishBias ? color.new(color.green, 97) : bearishBias ? color.new(color.red, 97) : na)

// === ALERTS ===
alertcondition(smartBuy, title="ENDGAME INST. BUY", message="ENDGAME RSI FLOW + JC ALIGNMENT BUY SIGNAL")

// === INFO TABLE ===
var table statusTable = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 20), border_width=1)

if barstate.islast
    table.cell(statusTable, 0, 0, "1D RSI", text_color=color.white)
    table.cell(statusTable, 1, 0, str.tostring(rsi1D, "#.##"), text_color=color.white)

    table.cell(statusTable, 0, 1, "4H RSI", text_color=color.white)
    table.cell(statusTable, 1, 1, str.tostring(rsi4h, "#.##"), text_color=color.white)

    table.cell(statusTable, 0, 2, "Trend", text_color=color.white)
    table.cell(statusTable, 1, 2, bullishBias ? "BULLISH" : bearishBias ? "BEARISH" : "NEUTRAL", text_color=bullishBias ? color.green : bearishBias ? color.red : color.gray)

    table.cell(statusTable, 0, 3, "Pricing Matrix", text_color=color.white)
    table.cell(statusTable, 1, 3, inDiscount ? "DISCOUNT" : "PREMIUM", text_color=inDiscount ? color.lime : color.orange)

    table.cell(statusTable, 0, 4, "Signal", text_color=color.white)
    table.cell(statusTable, 1, 4, smartBuy ? "BUY" : "WAIT / HUNT", text_color=smartBuy ? color.green : color.yellow)
